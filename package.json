{
  "name": "harmonia-bot",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "./node_modules/.bin/prisma generate && ./node_modules/.bin/tsc -p tsconfig.json",
    "start": "node --max-old-space-size=400 index.js",
    "dev": "tsx watch src/index.ts",
    "deploy-commands": "tsx src/scripts/deploy-commands.ts",
    "db:generate": "./node_modules/.bin/prisma generate",
    "db:push": "./node_modules/.bin/prisma db push",
    "db:migrate": "./node_modules/.bin/prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "discord.js": "^14.25.1",
    "shoukaku": "^4.2.0",
    "kazagumo": "^3.4.3",
    "axios": "^1.13.6",
    "ioredis": "^5.10.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "zod": "^3.24.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/cors": "^2.8.17",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.11",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}